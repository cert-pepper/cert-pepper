# CertPepper configuration
# Copy this file to .env and fill in your values

# Anthropic API key (required for AI explanations)
ANTHROPIC_API_KEY=sk-ant-...

# Database path (default: cert_pepper.db in current directory)
DB_PATH=./cert_pepper.db

# Content root: path to the directory containing your exam content
# For the built-in Security+ example:
CONTENT_ROOT=./examples/security-plus

# AI model settings
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# Study settings
DEFAULT_SESSION_SIZE=10
MASTERY_THRESHOLD=0.85
